#!/bin/bash
echo "start: chezmoi install script"

# bundle multiple formulas (text/CLI) and casks (graphical) into a single installation command
{{ if eq .chezmoi.os "darwin" -}}
    echo "install: brew bundle"
    brew bundle --file=/dev/stdin <<EOF
    {{ range .packages.darwin.taps }}
        tap {{ . | quote }}
    {{ end }}
    {{ range .packages.darwin.brews }}
        brew {{ . | quote }}
    {{ end }}
    {{ range .packages.darwin.casks }}
        cask {{ . | quote }}
    {{ end }}
EOF
# no whitespace before EOF
{{ end -}}

# doom
## required dependencies
echo "install: doom deps"
#brew install git ripgrep # in bundle above
# optional dependencies
# brew install coreutils fd # in bundle above
xcode-select -p &>/dev/null || xcode-select --install
echo "installed: doom deps"
#
## install
echo "install: doom"
if [ ! -d ~/.emacs.d ]; then
    git clone https://github.com/hlissner/doom-emacs ~/.emacs.d
    ~/.emacs.d/bin/doom install
fi
echo "installed: doom"

echo "*** End of Chezmoi install-packages script"
